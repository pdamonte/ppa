#!/bin/sh
set -e

DKMS_NAME="gc-cameras"
DKMS_VERSION="0.1.1"

if command -v dkms >/dev/null 2>&1; then
	if dkms status -m "${DKMS_NAME}" -v "${DKMS_VERSION}" 2>/dev/null | grep -q .; then
		dkms remove -m "${DKMS_NAME}" -v "${DKMS_VERSION}" --all || true
	fi
	dkms add -m "${DKMS_NAME}" -v "${DKMS_VERSION}" || true
	dkms build -m "${DKMS_NAME}" -v "${DKMS_VERSION}" || true
	dkms install -m "${DKMS_NAME}" -v "${DKMS_VERSION}" || true
fi

if command -v modprobe >/dev/null 2>&1; then
	modprobe -r gc8034 gti5035 intel_ipu6_isys intel_ipu6 ipu_bridge 2>/dev/null || true
	modprobe gti5035 2>/dev/null || true
	modprobe gc8034 2>/dev/null || true
	modprobe intel_ipu6_isys 2>/dev/null || true
fi

#DEBHELPER#

exit 0
